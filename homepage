<!DOCTYPE html>
<html class="light" lang="ko">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" name="viewport"/>
  <title>Editorial - Home</title>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#b6004f",
            "on-primary": "#ffffff",
            "surface": "#fff4f6",
            "on-surface": "#4a2135",
            "on-surface-variant": "#7d4d63",
            "surface-container-low": "#ffecf2",
            "surface-container-high": "#ffd8e7",
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f3f4f6; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .nav-item.active .material-symbols-outlined { font-variation-settings: 'FILL' 1; }
    .hide-scrollbar::-webkit-scrollbar { display: none; }
    .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    .page { display: none; flex-direction: column; height: 100%; position: relative; }
    .page.active { display: flex; }
    .mode-btn.active { background-color: #b6004f; color: white; }
  </style>
</head>
<body class="py-0 sm:py-8">
  <div id="app-shell" class="relative w-full max-w-[400px] h-[100dvh] sm:h-[850px] bg-surface overflow-hidden sm:shadow-2xl sm:rounded-[2.5rem] border border-rose-100 flex flex-col">
    
    <!-- HOME PAGE -->
    <section id="page-home" class="page active">
      <header class="shrink-0 bg-white/80 backdrop-blur-xl px-5 py-4 flex justify-between items-center border-b border-rose-100 z-10">
        <div class="flex items-center gap-2">
          <div class="h-8 w-8 rounded-full bg-primary flex items-center justify-center text-on-primary shadow-sm font-black text-[10px]">E</div>
          <h1 class="text-lg font-black tracking-tighter text-zinc-900">Editorial</h1>
        </div>
        <div class="flex items-center gap-1">
          <div class="flex bg-rose-50 p-1 rounded-full mr-1">
            <button onclick="toggleFeedMode('personal')" id="btn-personal" class="mode-btn active px-2.5 py-1 rounded-full text-[9px] font-bold transition-all">개인</button>
            <button onclick="toggleFeedMode('company')" id="btn-company" class="mode-btn px-2.5 py-1 rounded-full text-[9px] font-bold text-on-surface-variant transition-all">기업</button>
          </div>
          <button class="p-2 text-primary"><span class="material-symbols-outlined">search</span></button>
        </div>
      </header>
      <main id="feed-container" class="flex-1 overflow-y-auto p-4 space-y-6 hide-scrollbar pb-24"></main>
    </section>

    <!-- DETAIL PAGE -->
    <section id="page-detail" class="page bg-white">
      <header class="shrink-0 bg-white/80 backdrop-blur-xl px-5 py-4 flex items-center border-b border-rose-100 z-10">
        <button onclick="closeDetail()" class="text-primary mr-4 transition-transform active:scale-90"><span class="material-symbols-outlined">arrow_back_ios</span></button>
        <h1 class="font-bold text-primary tracking-tight">상세 정보</h1>
      </header>
      <main id="detail-content" class="flex-1 overflow-y-auto hide-scrollbar pb-24"></main>
    </section>

    <!-- NAVIGATION -->
    <nav class="absolute bottom-0 left-0 right-0 h-20 flex justify-around items-center px-6 pb-2 bg-white/90 backdrop-blur-xl rounded-t-[2.5rem] shadow-[0_-10px_40px_rgba(182,0,79,0.1)] z-50">
      <a href="index.html" class="nav-item active flex flex-col items-center gap-1 text-primary">
        <span class="material-symbols-outlined text-[24px]">home</span><span class="text-[9px] font-bold">홈</span>
      </a>
      <a href="create.html" class="nav-item flex flex-col items-center gap-1 text-zinc-400">
        <span class="material-symbols-outlined text-[24px]">add_circle</span><span class="text-[9px] font-bold">만들기</span>
      </a>
      <a href="messages.html" class="nav-item flex flex-col items-center gap-1 text-zinc-400">
        <span class="material-symbols-outlined text-[24px]">send</span><span class="text-[9px] font-bold">메시지</span>
      </a>
      <a href="profile.html" class="nav-item flex flex-col items-center gap-1 text-zinc-400">
        <span class="material-symbols-outlined text-[24px]">person</span><span class="text-[9px] font-bold">프로필</span>
      </a>
    </nav>
  </div>

  <script>
    const allProfiles = [
      { id: 1, type: 'personal', name: "김지수", handle: "@jisoo_style", img: "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=500&q=80", followers: "842", activity: "12.4%", reviews: 128, rating: "4.9", reviewSummary: "사진 퀄리티가 매우 높습니다.", interests: ["오가닉 뷰티", "건축"], brands: ["자크뮈스", "AESOP"], persona: { age: "24세 / 프리랜서 모델", personality: "트렌디함" } },
      { id: 4, type: 'company', name: "아우라 뷰티", handle: "@aura_skin_lab", img: "https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=500&q=80", category: "뷰티/코스메틱", response: "30분 이내", reviews: 520, rating: "4.9", reviewSummary: "훌륭한 브랜드입니다.", interests: ["클린 뷰티", "비건"], brands: ["이솝"], persona: { age: "설립 3년차", personality: "과학적 근거 중심" } }
    ];

    function toggleFeedMode(mode) {
      document.querySelectorAll('.mode-btn').forEach(b => {
        b.classList.remove('active', 'bg-primary', 'text-white');
        b.classList.add('text-on-surface-variant');
      });
      const activeBtn = document.getElementById('btn-' + mode);
      activeBtn.classList.add('active', 'bg-primary', 'text-white');
      renderFeed(mode);
    }

    function renderFeed(filter) {
      const container = document.getElementById('feed-container');
      const filtered = allProfiles.filter(p => p.type === filter);
      container.innerHTML = filtered.map(p => `
        <article class="bg-white rounded-[2rem] overflow-hidden shadow-sm border border-rose-50">
          <img class="w-full h-80 object-cover" src="${p.img}"/>
          <div class="p-6">
            <h2 class="text-xl font-extrabold text-on-surface">${p.name}</h2>
            <p class="text-xs text-on-surface-variant mb-4">${p.handle}</p>
            <button onclick="openDetail(${p.id})" class="w-full py-3.5 bg-primary text-white text-sm font-bold rounded-xl shadow-md">상세 정보 보기</button>
          </div>
        </article>
      `).join('');
    }

    function openDetail(id) {
      const p = allProfiles.find(item => item.id === id);
      const detailContent = document.getElementById('detail-content');
      detailContent.innerHTML = `<div class="p-6"><h2 class="text-2xl font-black">${p.name}</h2><p class="text-primary">${p.handle}</p><div class="mt-4 p-4 bg-rose-50 rounded-2xl">${p.persona.age}<br>${p.persona.personality}</div></div>`;
      document.getElementById('page-home').classList.remove('active');
      document.getElementById('page-detail').classList.add('active');
    }

    function closeDetail() {
      document.getElementById('page-detail').classList.remove('active');
      document.getElementById('page-home').classList.add('active');
    }

    window.onload = () => renderFeed('personal');
  </script>
</body>
</html>
